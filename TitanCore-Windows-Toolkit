# ==============================================================================
# TITAN CORE V12 - ENTERPRISE RMM PLATFORM (PT-BR)
# ==============================================================================

param([switch]$RunSilent)

# Configurações de Ambiente
$LogDir = "$env:ProgramData\TitanCore_Logs"
$LogFile = "$LogDir\execucao.log"

if (!(Test-Path $LogDir)) { New-Item -ItemType Directory -Path $LogDir -Force | Out-Null }

# ------------------------------------------------------------------------------
# MOTOR DE LOGS E EXECUÇÃO
# ------------------------------------------------------------------------------

function Write-Log {
    param($Msg, $Color="White")
    $time = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$time - [$($Color.ToUpper())] - $Msg" | Out-File $LogFile -Append
    Write-Host "[*] $Msg" -ForegroundColor $Color
}

function Run-Process {
    param([string]$File, [string[]]$CmdArgs, [int]$Timeout = 1800)
    try {
        $p = Start-Process -FilePath $File -ArgumentList $CmdArgs -PassThru -NoNewWindow
        if (!$p.WaitForExit($Timeout * 1000)) {
            $p.Kill()
            Write-Log "Processo $File travou e foi encerrado." "Red"
        }
    } catch {
        Write-Log "Erro ao executar $File : $_" "Red"
    }
}

# ------------------------------------------------------------------------------
# MÓDULOS DE REMEDIAÇÃO
# ------------------------------------------------------------------------------

function Invoke-OSHealthRemediation {
    Write-Log "Iniciando Verificação de Integridade (SFC)..." "Yellow"
    Run-Process "sfc.exe" @("/scannow")
    Write-Log "Iniciando Reparo de Imagem (DISM)..." "Yellow"
    Run-Process "DISM.exe" @("/Online", "/Cleanup-Image", "/RestoreHealth")
    Write-Log "Remediação do SO concluída." "Green"
}

function Invoke-SystemPurge {
    Write-Log "Limpando Caches e Arquivos Temporários..." "Yellow"
    Stop-Service wuauserv, bits -Force -ErrorAction SilentlyContinue -WarningAction SilentlyContinue
    $Paths = @("C:\Windows\Temp\*", "$env:TEMP\*", "C:\Windows\Prefetch\*")
    foreach ($P in $Paths) {
        Get-ChildItem $P -Recurse -ErrorAction SilentlyContinue | Remove-Item -Force -Recurse -ErrorAction SilentlyContinue
    }
    Start-Service wuauserv, bits -ErrorAction SilentlyContinue -WarningAction SilentlyContinue
    Write-Log "Limpeza concluída." "Green"
}

function Invoke-NetworkStackReset {
    Write-Log "Resetando Pilha TCP/IP e DNS..." "Yellow"
    ipconfig /release | Out-Null
    ipconfig /flushdns | Out-Null
    netsh winsock reset | Out-Null
    netsh int ip reset | Out-Null
    
    Write-Log "Reiniciando Adaptadores de Rede..." "Cyan"
    Get-NetAdapter | Where-Object Status -eq "Up" | Restart-NetAdapter -Confirm:$false
    Write-Log "Rede restaurada." "Green"
}

function Test-NetworkTelemetry {
    Write-Log "Coletando Diagnóstico de Conectividade..." "Cyan"
    Test-NetConnection google.com -InformationLevel Detailed
    Get-NetIPAddress -AddressFamily IPv4 | Select-Object InterfaceAlias, IPAddress
}

# ------------------------------------------------------------------------------
# MÓDULOS AVANÇADOS (GOD MODE)
# ------------------------------------------------------------------------------

function Invoke-TCPAudit {
    Write-Log "Auditando Portas e Processos (Uvicorn/FastAPI)..." "Cyan"
    $Port = Read-Host "Digite a porta (ex: 8000) ou ENTER para listar todas"
    if ([string]::IsNullOrWhiteSpace($Port)) {
        Get-NetTCPConnection -State Listen | Select-Object LocalPort, OwningProcess | Sort-Object LocalPort
    } else {
        $Conn = Get-NetTCPConnection -LocalPort $Port -ErrorAction SilentlyContinue
        if ($Conn) {
            $Proc = Get-Process -Id $Conn.OwningProcess
            Write-Log "Porta $Port ocupada por: $($Proc.ProcessName) (PID: $($Proc.Id))" "Yellow"
            $Conf = Read-Host "Deseja forçar o encerramento? (S/N)"
            if ($Conf -eq "S") { Stop-Process -Id $Proc.Id -Force; Write-Log "Processo encerrado." "Green" }
        } else { Write-Log "Porta $Port está livre." "White" }
    }
}

function Export-ForensicDashboard {
    Write-Log "Gerando Dashboard Forense HTML..." "Cyan"
    $OutPath = "$env:USERPROFILE\Desktop\Relatorio_Forense_Titan.html"
    
    $OS = Get-CimInstance Win32_OperatingSystem
    $RAM = Get-CimInstance Win32_PhysicalMemory | Measure-Object -Property Capacity -Sum
    
    $HTML = @"
    <html><body style='font-family:sans-serif; background:#121212; color:#fff; padding:30px;'>
    <h1 style='color:#00bcff;'>Titan Core V12 - Relatório de Endpoint</h1>
    <hr>
    <p><b>Hostname:</b> $env:COMPUTERNAME</p>
    <p><b>Sistema:</b> $($OS.Caption)</p>
    <p><b>Memória RAM:</b> $([math]::Round($RAM.Sum / 1GB, 2)) GB</p>
    <p style='color:#888;'>Gerado em: $(Get-Date)</p>
    </body></html>
"@
    $HTML | Out-File $OutPath -Encoding UTF8
    Write-Log "Relatório exportado para sua Área de Trabalho." "Green"
    Invoke-Item $OutPath
}

function Register-ZeroTouch {
    Write-Log "Agendando Manutenção Automática (Domingo 03:00)..." "Yellow"
    $Action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-WindowStyle Hidden -Command `"& { (Get-Content '$PSCommandPath' -Raw) | IEX } -RunSilent`""
    $Trigger = New-ScheduledTaskTrigger -Weekly -DaysOfWeek Sunday -At 3:00AM
    Register-ScheduledTask -TaskName "TitanCore_AutoFix" -Action $Action -Trigger $Trigger -User "SYSTEM" -RunLevel Highest -Force | Out-Null
    Write-Log "Tarefa agendada com sucesso." "Green"
}

# ------------------------------------------------------------------------------
# INTERFACE PRINCIPAL
# ------------------------------------------------------------------------------

if ($RunSilent) {
    Invoke-OSHealthRemediation
    Invoke-SystemPurge
    exit
}

function Show-Menu {
    Clear-Host
    Write-Host "=====================================================" -ForegroundColor Cyan
    Write-Host "     TITAN CORE V12 - MODO ENTERPRISE (GOD MODE)     " -ForegroundColor White
    Write-Host "=====================================================" -ForegroundColor Cyan
    Write-Host " [01] Remediação de Integridade do SO (SFC/DISM)"
    Write-Host " [02] Purga de Cache e Arquivos Temporários"
    Write-Host " [03] Reset Absoluto de Rede (TCP/IP e DNS)"
    Write-Host " [04] Telemetria e Diagnóstico de Rede"
    Write-Host " [05] Auditoria de Portas e Processos (Dev Mode)"
    Write-Host " [06] Dashboard Forense (Relatório HTML)" -ForegroundColor Green
    Write-Host " [07] Agendar Manutenção Automática (Zero-Touch)" -ForegroundColor Green
    Write-Host " [99] Rotina Técnica Completa (Enterprise)" -ForegroundColor Magenta
    Write-Host " [00] Sair do Sistema"
    Write-Host "=====================================================" -ForegroundColor Cyan
}

while ($true) {
    Show-Menu
    $op = Read-Host "TitanCore@Comando"
    switch ($op) {
        "1"  { Invoke-OSHealthRemediation }
        "2"  { Invoke-SystemPurge }
        "3"  { Invoke-NetworkStackReset }
        "4"  { Test-NetworkTelemetry }
        "5"  { Invoke-TCPAudit }
        "6"  { Export-ForensicDashboard }
        "7"  { Register-ZeroTouch }
        "99" { 
            Invoke-OSHealthRemediation
            Invoke-SystemPurge
            Invoke-NetworkStackReset
            Write-Log "Rotina completa finalizada." "Magenta" 
        }
        "0"  { exit }
    }
    Write-Host "`nPressione Enter para voltar ao menu..."
    $null = Read-Host
}
